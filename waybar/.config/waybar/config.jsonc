{
"modules-left": [
    "ext/workspaces",
    "dwl/tags",
    "dwl/window"
],

"modules-right": [
    "battery",
    "memory",
    "network",
    "clock",
    "tray"
],

"ext/workspaces": {
    "format": "{icon}",
    "ignore-hidden": true,
    "on-click": "activate",
    "sort-by-id": true,
},
  
"dwl/tags": {
      "num-tags":9,
},
  
"dwl/window": {
      "format": "[{layout}]{title}"
}


}

